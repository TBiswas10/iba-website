generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres.zqaugesqeehuubcytlfw:9oKTsifFm4c3YWoV@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?connection_limit=1"
}

model User {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  name         String?
  passwordHash String?
  role         UserRole     @default(USER)
  memberships  Membership[]
  donations    Donation[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Event {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  start       DateTime
  end         DateTime
  location    String?
  description String?
  imageUrl    String?
  rsvps       Rsvp[]
  albums      Album[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Album {
  id          Int           @id @default(autoincrement())
  title       String
  description String?
  coverUrl    String?
  eventId     Int?
  event       Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  items       GalleryItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([eventId])
}

model Rsvp {
  id                         Int      @id @default(autoincrement())
  eventId                    Int
  name                       String
  email                      String
  phone                      String
  attendees                  Int
  kidsCount                  Int?
  kidsAges                   String?
  confirmationEmailSentAt    DateTime?
  confirmationEmailError     String?
  event                      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([eventId])
  @@index([email])
  @@index([createdAt])
}

model Membership {
  id         Int              @id @default(autoincrement())
  userId     Int
  status     MembershipStatus @default(PENDING)
  startDate  DateTime
  expiryDate DateTime
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([userId])
}

model Donation {
  id            Int      @id @default(autoincrement())
  userId        Int?
  amountCents   Int
  currency      String   @default("AUD")
  status        String
  provider      String   @default("stripe")
  providerRef   String?
  donorName     String?
  donorEmail    String?
  message       String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model GalleryItem {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  mediaUrl    String
  mediaType   String   @default("image")
  albumId     Int?
  album       Album?   @relation(fields: [albumId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([albumId])
}

model Resource {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  category    String?
  url         String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WebhookEvent {
  id              Int       @id @default(autoincrement())
  provider        String
  providerEventId String    @unique
  eventType       String
  processedAt     DateTime?
  error           String?
  createdAt       DateTime  @default(now())
}

enum UserRole {
  ADMIN
  USER
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  PENDING
}
